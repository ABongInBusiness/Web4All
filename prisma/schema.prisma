generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole           { CUSTOMER ADMIN }
enum PlanType           { STANDARD_PRO ENTERPRISE }
enum BillingCycle       { MONTHLY ANNUAL }
enum PaymentType        { ONE_TIME RECURRING }
enum SubscriptionStatus { PENDING ACTIVE CANCELLED EXPIRED }
enum DeliveryStatus     { AWAITING_ONBOARDING ONBOARDING_COMPLETE IN_PROGRESS REVIEW LIVE }
enum TicketStatus       { OPEN IN_PROGRESS RESOLVED CLOSED }
enum WebsiteType        { INDIVIDUAL BUSINESS }